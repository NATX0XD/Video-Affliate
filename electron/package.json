{
  "name": "vgap",
  "version": "1.0.0",
  "description": "VDO Gen Auto Pilot",
  "main": "main.js",
  "scripts": {
    "dev":        "electron .",
    "build":      "electron-builder --mac --win",
    "build:mac":  "electron-builder --mac",
    "build:win":  "electron-builder --win"
  },
  "build": {
    "appId":       "com.vgap.app",
    "productName": "VDO Gen Auto Pilot",
    "directories": {
      "output": "../dist"
    },
    "files": [
      "main.js"
    ],
    "extraResources": [
      { "from": "../web/out",          "to": "web/out",    "filter": ["**/*"] },
      { "from": "../desktop/dist",     "to": "backend",    "filter": ["**/*"] },
      { "from": "bin",                 "to": "bin",        "filter": ["**/*"] }
    ],
    "mac": {
      "target": [{ "target": "dmg", "arch": ["arm64", "x64"] }],
      "icon": "assets/icon.icns",
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "installerLanguages": ["th"]
    },
    "dmg": {
      "title": "VDO Gen Auto Pilot ${version}",
      "window": { "width": 540, "height": 380 }
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://UPDATE_HOST_URL/vgap/"
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron":         "^32.0.0",
    "electron-builder": "^25.0.0"
  }
}
