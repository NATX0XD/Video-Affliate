#!/bin/bash
# ============================================================
#  setup-mac.command — ทางลัดมาที่ตัวติดตั้งหลัก "ติดตั้ง.command"
#  (เดิมสคริปต์ติดตั้งอยู่ที่นี่ ตอนนี้ย้ายไปรวมที่ ติดตั้ง.command แล้ว
#   เพื่อลดความซ้ำซ้อน — คงไฟล์นี้ไว้ให้คนที่คุ้นชื่อเดิมยังใช้ได้)
#  วิธีใช้: ดับเบิลคลิกไฟล์นี้  หรือ  bash setup-mac.command
# ============================================================
DIR="$(cd "$(dirname "$0")" && pwd)"
exec "$DIR/ติดตั้ง.command"
