{
  "manifest_version": 3,
  "name": "Shopee VDO Gen",
  "version": "3.27.4",
  "description": "ตัวช่วยดูดสินค้าจาก Shopee เข้าคลังในแอป VDO Gen (localhost:3001) + ขับ Flow สร้างคลิปอัตโนมัติ — ศูนย์ควบคุมอยู่บนเว็บแอป",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "downloads",
    "tabs",
    "sidePanel",
    "debugger",
    "alarms"
  ],
  "host_permissions": [
    "https://shopee.co.th/*",
    "https://affiliate.shopee.co.th/*",
    "https://labs.google/*",
    "https://accounts.google.com/*",
    "https://generativelanguage.googleapis.com/*",
    "http://localhost/*"
  ],
  "action": {
    "default_title": "Shopee VDO Gen — เปิดตัวช่วยดูดสินค้า"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://shopee.co.th/*",
        "https://affiliate.shopee.co.th/*"
      ],
      "js": [
        "content/util.js",
        "content/scraper.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://labs.google/*"
      ],
      "js": [
        "content/util.js",
        "content/flow.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://accounts.google.com/*"
      ],
      "js": [
        "content/gauth.js"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "flow-adapter.json"
      ],
      "matches": [
        "https://labs.google/*"
      ]
    }
  ],
  "key": ""
}